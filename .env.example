# ── Application ───────────────────────────────────────────────────────────────
# Runtime environment: dev | prod
# In prod, API_KEY must be changed and rate limits are enforced more strictly.
APP_ENV=dev

# ── LLM Provider ──────────────────────────────────────────────────────────────
# Which backend to use: ollama | openwebui
LLM_PROVIDER=ollama

# Ollama settings (used when LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:3b

# Open WebUI settings (used when LLM_PROVIDER=openwebui)
OPENWEBUI_BASE_URL=
OPENWEBUI_API_KEY=
OPENWEBUI_MODEL=
OPENWEBUI_CHAT_PATH=/api/chat/completions

# ── Security ──────────────────────────────────────────────────────────────────
# Server-to-server API key; must be changed in prod
API_KEY=replace-with-a-strong-key

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:3000,https://your-embed-host.com

# Short-lived HMAC secret for embed tokens; must be changed in prod
EMBED_TOKEN_SECRET=replace-with-a-long-random-secret

# Embed token TTL in seconds (min 60)
EMBED_TOKEN_TTL_SECONDS=180

# ── Rate limiting & Validation ────────────────────────────────────────────────
REQUEST_TIMEOUT=60
HEALTH_TIMEOUT=5
RATE_LIMIT_PER_MIN=15
MAX_MESSAGE_CHARS=2000
MAX_HISTORY_ITEMS=12

# ── Storage ───────────────────────────────────────────────────────────────────
BOT_REGISTRY_DB_PATH=./data/bots.sqlite3

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=DEBUG

# Maximum characters to include per message/reply in structured logs (0 = unlimited)
LOG_CONTENT_MAX_CHARS=500

# Set to true to write chat turns to logs/chat.csv (daily rotating)
CHAT_LOG_ENABLED=false
